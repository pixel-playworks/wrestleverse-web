---
import Hero from "@components/Hero.astro";
import Header from "@components/Header.astro";
import Layout from "@layouts/Layout.astro";
import Footer from "@components/Footer.astro";
---

<Layout>
  <Header />

  <main>
    <Hero />
  </main>

  <Footer />
</Layout>

<style>
  /* ─── Container ─────────────────────────────── */
  .container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 40px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .nav-logo-icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.3px;
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 768px) {
    .container {
      padding-inline: 1.25rem;
    }
  }
</style>
