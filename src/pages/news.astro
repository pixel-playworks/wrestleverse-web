---
import "../styles/global.css";
import Header from "@components/Header.astro";
import Layout from "@layouts/Layout.astro";
import NewsCard from "@components/NewsCard.astro";
import { getCollection } from "astro:content";

// `getCollection` returns all entries in the `news` content collection.
// We sort by `date` descending so the newest article appears first.
const posts = await getCollection("news");
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout
  title="News | WrestleVerse"
  description="Stay up to date with the latest WrestleVerse news and updates."
>
  <Header />

  <main class="news-page">
    <div class="news-shell">
      <section class="news-intro" aria-labelledby="news-heading">
        <p class="news-kicker">News</p>
      </section>

      <section class="news-grid" aria-label="Latest news">
        {sortedPosts.map((post) => <NewsCard post={post} />)}
      </section>
    </div>
  </main>
</Layout>

<style>
  .news-page {
    min-height: calc(100svh - 96px);
    padding: 96px 24px 120px;
    background: var(--color-bg);
  }

  .news-shell {
    width: min(100%, 1200px);
    margin-inline: auto;
  }

  .news-intro {
    margin-bottom: 64px;
  }

  .news-kicker {
    margin-bottom: 16px;
    font-family: var(--font-rounded);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--btn-bg);
  }

  /* Responsive grid matching the design spec:
     3 columns by default, 2 below 1400px, 1 below 960px. */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 64px;
    justify-items: center;
  }

  @media (max-width: 1400px) {
    .news-grid {
      grid-template-columns: repeat(2, minmax(0, 348px));
      justify-content: center;
    }
  }

  @media (max-width: 960px) {
    .news-page {
      padding: 64px 24px 96px;
    }

    .news-intro {
      margin-bottom: 40px;
    }

    .news-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
