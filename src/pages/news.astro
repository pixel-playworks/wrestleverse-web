---
import "../styles/global.css";
import Header from "@components/Header.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="News | WrestleVerse"
  description="Stay up to date with the latest WrestleVerse news and updates."
>
  <Header />

  <main class="news-page">
    <div class="news-shell">
      <section class="news-intro" aria-labelledby="news-heading">
        <p class="news-kicker">News</p>
        <h1 class="news-heading" id="news-heading">
          Stay up to date with the latest WrestleVerse news and updates.
        </h1>
      </section>
    </div>
    </main>