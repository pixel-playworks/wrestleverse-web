---
import "../../styles/global.css";
import Header from "@components/Header.astro";
import Layout from "@layouts/Layout.astro";
import { formatNewsDate } from "@scripts/format-date";
import { getCollection, render } from "astro:content";

// `getStaticPaths` tells Astro every URL this route should generate at build time.
export async function getStaticPaths() {
  const posts = await getCollection("news");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
// `render()` converts the Markdown body into an Astro component (`Content`).
const { Content } = await render(post);
const { title, date } = post.data;
---

<Layout
  title={`${title} | WrestleVerse`}
  description={`Read the latest WrestleVerse news: ${title}.`}
>
  <Header />

  <main class="article-page">
    <article class="article-shell">
      <header class="article-header">
        <p class="article-kicker">News</p>
        <h1 class="article-title">{title}</h1>
        <time class="article-date" datetime={date.toISOString()}
          >{formatNewsDate(date)}</time
        >
      </header>

      <div class="article-body">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .article-page {
    min-height: calc(100svh - 96px);
    padding: 96px 24px 120px;
    background: var(--color-bg);
  }

  .article-shell {
    width: min(100%, 980px);
    margin-inline: auto;
  }

  .article-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 40px;
    margin-bottom: 56px;
  }

  .article-kicker {
    margin-bottom: 16px;
    font-family: var(--font-rounded);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--btn-bg);
  }

  /* Matches the About page's h1 styling. */
  .article-title {
    max-width: 820px;
    margin-bottom: 32px;
    font-family: var(--font-display);
    font-size: clamp(3rem, 11vw, 8rem);
    font-weight: 500;
    line-height: 1;
    color: rgb(255 255 255 / 92%);
    text-shadow: 0 4px 18px rgb(184 200 255 / 18%);
  }

  .article-date {
    display: block;
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: rgb(255 255 255 / 60%);
  }

  .article-body {
    font-family: var(--font-body);
    font-size: 1.25rem;
    line-height: 1.7;
    color: rgb(255 255 255 / 68%);
  }

  /* `:global()` is needed because Markdown-rendered elements are injected at runtime. */
  .article-body :global(h1) {
    margin-top: 56px;
    margin-bottom: 20px;
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 500;
    line-height: 1.05;
    color: var(--color-text);
  }

  .article-body :global(h1:first-child) {
    margin-top: 0;
  }

  .article-body :global(h2) {
    margin-top: 48px;
    margin-bottom: 16px;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 500;
    line-height: 1.2;
    color: rgb(255 255 255 / 90%);
  }

  .article-body :global(h3) {
    margin-top: 40px;
    margin-bottom: 12px;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 500;
    line-height: 1.2;
    color: rgb(255 255 255 / 80%);
  }

  .article-body :global(p) {
    margin-bottom: 18px;
    max-width: 820px;
  }

  .article-body :global(ul) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    max-width: 820px;
    margin-top: 8px;
    margin-bottom: 24px;
    padding-left: 0;
    list-style: none;
  }

  .article-body :global(li) {
    min-height: 56px;
    border: 1px solid rgb(184 200 255 / 16%);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    background: rgb(255 255 255 / 4%);
    box-shadow: 0 16px 40px rgb(0 0 0 / 24%);
    font-family: var(--font-rounded);
    font-size: 1.05rem;
    line-height: 1.35;
    color: rgb(255 255 255 / 84%);
  }

  .article-body :global(li p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(em),
  .article-body :global(i) {
    font-style: italic;
    color: rgb(255 255 255 / 92%);
  }

  .article-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin-block: 24px;
  }

  .article-body :global(a) {
    color: var(--hyperlinks);
    text-decoration: underline;
    transition: opacity var(--transition);
  }

  .article-body :global(a:hover) {
    opacity: 0.85;
  }

  @media (max-width: 1140px) {
    .article-page {
      padding: 64px 24px 96px;
    }

    .article-body {
      font-size: 1.125rem;
    }
  }
</style>
