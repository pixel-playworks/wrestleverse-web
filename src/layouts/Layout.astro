---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "WrestleVerse | The Ultimate Wrestling Management Game",
  description = "Experience the most immersive wrestling management game on iOS and Android. No lootboxes. No subs. No bullshit.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="c3c440f7-e621-44dc-8d65-3c933840a447"></script>
  </head>
  <body>
    <slot />

    <script>
      import { configureCtaLinks } from "@scripts/cta-links";

      configureCtaLinks();
    </script>
  </body>
</html>
