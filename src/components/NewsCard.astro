---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { formatRelativeDate } from "@scripts/format-date";

interface Props {
  post: CollectionEntry<"news">;
}

const { post } = Astro.props;
const { title, date, image } = post.data;
---

<a href={`/news/${post.id}`} class="news-card">
  <!-- `image` here is the resolved asset object from the schema's `image()` helper;
      Astro optimizes it at build time and generates a responsive srcset. -->
  <Image
    src={image}
    alt=""
    width={348}
    height={348}
    densities={[1, 2]}
    class="news-card__image"
  />
  <div class="news-card__overlay">
    <div class="news-card__text">
      <time
        class="news-card__subtitle"
        datetime={date.toISOString()}
        data-relative>{formatRelativeDate(date)}</time
      >
      <h2 class="news-card__title">{title}</h2>
    </div>
  </div>
</a>

<style>
  .news-card {
    position: relative;
    display: block;
    width: 100%;
    max-width: 348px;
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    overflow: hidden;
    isolation: isolate;
  }

  .news-card__image {
    position: absolute;
    inset: -1px;
    display: block;
    width: calc(100% + 2px);
    height: calc(100% + 2px);
    object-fit: cover;
  }
  .news-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(
        to bottom,
        rgba(27, 43, 95, 0.7),
        rgba(27, 43, 95, 1)
      )
      bottom / 100% 84px no-repeat;
  }

  .news-card__overlay::before {
    content: "";
    position: absolute;
    inset: auto 0 -4px 0;
    height: 88px;
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
    pointer-events: none;
  }

  .news-card__text {
    position: relative;
    height: 84px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2px;
    padding-left: 20px;
  }

  .news-card__title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    line-height: 1.2;
    color: #ffffff;
  }

  .news-card__subtitle {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.6);
  }
</style>

<!-- Re-compute the relative date in the browser so "ago" is measured from the
     visit, not the last build  -->
<script>
  import { formatRelativeDate } from "@scripts/format-date";

  for (const el of document.querySelectorAll<HTMLTimeElement>(
    "time[data-relative]",
  )) {
    el.textContent = formatRelativeDate(new Date(el.dateTime));
  }
</script>
