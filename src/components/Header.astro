---
const navLinks = [
  { label: "About", href: "#about" },
  { label: "Features", href: "#features" },
  { label: "News", href: "#news" },
  { label: "Roadmap", href: "#roadmap" },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="brand" aria-label="WrestleVerse home">
      <img
        src="/PrimaryRounded_Web.png"
        alt="WrestleVerse logo"
        class="brand__icon"
      />
      <span class="brand__name">WrestleVerse</span>
    </a>

    <nav class="primary-nav" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a href={link.href} class="primary-nav__link">
            {link.label}
          </a>
        ))
      }
    </nav>
    <a href="#features" class="play-button">Play Now</a>
  </div>
</header>

<style>
  .site-header {
    height: 96px;
    background: var(--color-bg);
  }

  .site-header__inner {
    width: 100%;
    height: 100%;
    padding-inline: 24px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    justify-self: start;
  }

  .brand__icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .brand__name {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--color-text);
  }

  .primary-nav {
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .primary-nav__link,
  .play-button {
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1;
    white-space: nowrap;
    transition: background-color var(--transition);
  }

  .primary-nav__link {
    padding-inline: 22px;
    background: var(--accent-color);
    color: var(--color-text);
  }

  .primary-nav__link:hover {
    background: var(--accent-color-hover);
  }

  .play-button {
    justify-self: end;
    padding-inline: 24px;
    background: var(--btn-bg);
    color: #101c40;
  }

  .play-button:hover {
    background: var(--btn-bg-hover);
  }

  .brand:focus-visible,
  .primary-nav__link:focus-visible,
  .play-button:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 3px;
  }

  @media (max-width: 1080px) {
    .site-header__inner {
      gap: 1.25rem;
    }

    .brand__name {
      font-size: 1.5rem;
    }

    .primary-nav {
      gap: 10px;
    }

    .primary-nav__link,
    .play-button {
      height: 48px;
      padding-inline: 16px;
      font-size: 1.125rem;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      height: auto;
    }

    .site-header__inner {
      grid-template-columns: 1fr auto;
      gap: 16px;
      padding: 16px;
    }

    .brand__icon {
      width: 40px;
      height: 40px;
    }

    .primary-nav {
      grid-column: 1 / -1;
      grid-row: 2;
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .primary-nav::-webkit-scrollbar {
      display: none;
    }
  }
</style>
