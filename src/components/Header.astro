---
import { Image } from "astro:assets";
import { APP_STORE_URL } from "@scripts/store-links";
import brandLogo from "@assets/images/PrimaryRounded_Web.png";

const navLinks = [
  { label: "About", href: "/about" },
  {
    label: "Features",
    href: APP_STORE_URL,
    target: "_blank",
    isCta: true,
  },
  { label: "News", href: "/news" },
  {
    label: "Roadmap",
    href: "https://pixelplayworks.notion.site/wrestleverse-roadmap",
    target: "_blank",
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

// Highlight `/news` on both `/news` and `/news/[slug]`.
const isActiveLink = (href: string) =>
  href.startsWith("/") &&
  `${currentPath}/`.startsWith(`${href.replace(/\/$/, "") || "/"}/`);
---

<header class="site-header">
  <div class="site-header__inner">
    <a
      href="/"
      class="brand"
      aria-label="WrestleVerse home"
      data-umami-event="Nav Link - Logo"
    >
      <Image
        src={brandLogo}
        alt="WrestleVerse logo"
        class="brand__icon"
        width={48}
        height={48}
        densities={[1, 2]}
        priority
      />
      <span class="brand__name">WrestleVerse</span>
    </a>

    <nav class="primary-nav" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            target={link.target}
            rel={link.target === "_blank" ? "noopener noreferrer" : undefined}
            data-cta-link={link.isCta ? "" : undefined}
            data-umami-event={
              link.isCta ? "CTA Click" : `Nav Link - ${link.label}`
            }
            class:list={[
              "primary-nav__link",
              { "primary-nav__link--active": isActiveLink(link.href) },
            ]}
            aria-current={isActiveLink(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <a
      href={APP_STORE_URL}
      class="play-button"
      data-cta-link
      data-umami-event="CTA Click"
      target="_blank"
      rel="noopener noreferrer">Play Now</a
    >

    <details class="mobile-menu">
      <summary class="mobile-menu__toggle">
        <!-- The span with the sr-only class is hidden visually, 
        but it is still accessible to screen readers. This is a common technique used to provide additional information 
        to screen readers that is not visible to sighted users. -->
        <span class="sr-only">Navigation menu</span>
        <span class="mobile-menu__line mobile-menu__line--top"></span>
        <span class="mobile-menu__line mobile-menu__line--middle"></span>
        <span class="mobile-menu__line mobile-menu__line--bottom"></span>
      </summary>

      <nav class="mobile-menu__panel" aria-label="Mobile navigation">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              target={link.target}
              rel={link.target === "_blank" ? "noopener noreferrer" : undefined}
              data-cta-link={link.isCta ? "" : undefined}
              data-umami-event={
                link.isCta ? "CTA Click" : `Nav Link - ${link.label}`
              }
              class:list={[
                "mobile-menu__link",
                // if the link is active, add the class "mobile-menu__link--active"
                { "mobile-menu__link--active": isActiveLink(link.href) },
              ]}
              aria-current={isActiveLink(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))
        }
        <a
          href={APP_STORE_URL}
          class="mobile-menu__cta"
          data-cta-link
          data-umami-event="CTA Click"
          target="_blank"
          rel="noopener noreferrer">Play Now</a
        >
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    height: 96px;
    background: var(--color-bg);
  }

  .site-header__inner {
    width: 100%;
    height: 100%;
    padding-inline: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .brand {
    position: absolute;
    left: 24px;
    display: inline-flex; /* display: flex creates a flexbox layout */
    align-items: center;
    gap: 12px;
  }

  .brand__icon {
    width: 48px;
    height: 48px;
  }

  .brand__name {
    font-family: var(--font-rounded);
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: normal;
    color: var(--color-text);
  }

  .primary-nav {
    display: flex; /* display: flex creates a flexbox layout */
    gap: 20px;
  }

  .primary-nav__link,
  .play-button {
    height: 56px;
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-md);
    font-family: var(--font-rounded);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1;
    white-space: nowrap;
    transition: background-color var(--transition);
  }

  .primary-nav__link {
    padding-inline: 22px;
    background: var(--accent-color);
  }

  .primary-nav__link:hover {
    background: var(--accent-color-hover);
  }

  .primary-nav__link--active,
  .primary-nav__link--active:hover {
    background: var(--btn-bg-selected);
  }

  .play-button {
    position: absolute;
    right: 24px;
    padding-inline: 24px;
    background: var(--btn-bg);
    color: #101c40;
  }

  .play-button:hover {
    background: var(--btn-bg-hover);
  }

  /* If it is hidden visually with display: none;, screen readers ignore it. */
  .mobile-menu {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    /* The inset() CSS function defines a rectangle at the specified inset distances from each side of the reference box */
    clip-path: inset(50%);
  }

  /* Focus visible is used to show a visual indicator when tabbing through an element */
  .brand:focus-visible,
  .primary-nav__link:focus-visible,
  .play-button:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 3px;
  }

  @media (max-width: 1140px) {
    .site-header {
      position: relative;
      z-index: 10;
    }

    .site-header__inner {
      display: flex;
      justify-content: space-between;
      padding: 24px;
    }

    .brand {
      position: static;
    }

    .brand__name {
      /* clamp() is a function that creates a fluid typography by taking three values: a minimum size, a preferred size, and a maximum size */
      /* Fluid typography without the use of media queries. */
      font-size: clamp(1.65rem, 7.4vw, 2.25rem);
    }

    .primary-nav,
    .play-button {
      display: none;
    }

    .mobile-menu {
      display: block;
    }

    .mobile-menu__toggle {
      display: flex;
      flex-direction: column;
      gap: 7px;
      cursor: pointer;
      list-style: none;
    }

    .mobile-menu__toggle::-webkit-details-marker {
      display: none;
    }

    .mobile-menu__line {
      width: 34px;
      height: 4px;
      border-radius: 999px;
      background: var(--btn-bg);
      transform-origin: center;
      transition:
        opacity var(--transition),
        transform var(--transition);
    }

    /* The details element opens and closes  */
    /* eg <details class="mobile-menu" open> */
    .mobile-menu[open] .mobile-menu__line--top {
      transform: translateY(11px) rotate(45deg);
    }

    .mobile-menu[open] .mobile-menu__line--middle {
      opacity: 0;
    }

    .mobile-menu[open] .mobile-menu__line--bottom {
      transform: translateY(-11px) rotate(-45deg);
    }

    .mobile-menu__toggle:focus-visible {
      outline: 2px solid var(--color-text);
      outline-offset: 3px;
      border-radius: var(--radius-sm);
    }

    .mobile-menu__panel {
      position: absolute;
      top: 100%;
      /* Spacing when mobile menu is open, does not get affected by the .site-header__inner padding */
      inset-inline: 0;
      min-height: calc(100svh - 96px);
      padding: 20px 16px 40px;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 16px;
      background: var(--color-bg);
    }

    .mobile-menu__link,
    .mobile-menu__cta {
      min-width: 156px;
      height: 56px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-md);
      font-family: var(--font-rounded);
      font-size: 1.25rem;
      font-weight: 500;
      transition: background-color var(--transition);
    }

    .mobile-menu__link {
      color: var(--color-text);
      background: var(--accent-color);
    }

    .mobile-menu__link:hover {
      background: var(--accent-color-hover);
    }

    .mobile-menu__link--active,
    .mobile-menu__link--active:hover {
      background: var(--btn-bg-selected);
    }

    .mobile-menu__cta {
      color: #101c40;
      background: var(--btn-bg);
    }

    .mobile-menu__cta:hover {
      background: var(--btn-bg-hover);
    }

    .mobile-menu__link:focus-visible,
    .mobile-menu__cta:focus-visible {
      outline: 2px solid var(--color-text);
      outline-offset: 3px;
    }
  }
</style>
